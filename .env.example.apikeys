# API Keys Configuration
# Almacenamiento seguro de API keys en la base de datos

# Google Gemini API Key
# Obtén tu key en: https://ai.google.dev/
# Esta key se usará para inicializar la BD en scripts/initializeApiKeys.js
GEMINI_API_KEY=AIzaSyBx88IXjw4nOEH7Wdxzdle-4tmbY_9wZZ8

# Nota: Después de ejecutar initializeApiKeys.js, esta key se almacena en MongoDB
# y se obtiene dinámicamente desde la BD en lugar de usar esta variable.
# 
# Esto significa:
# 1. Puedes cambiar la key en la BD sin tocar este .env
# 2. No necesitas redeploy para cambiar keys
# 3. Las keys no viajen en el código fuente
#
# Para cambiar la key después del primer setup:
# curl -X POST http://localhost:3000/api/api-key/update \
#   -H "Content-Type: application/json" \
#   -d '{"service":"gemini","apiKey":"NUEVA_KEY_AQUI"}'

# Futuros servicios (cuando sea necesario)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
# STRIPE_API_KEY=sk_live_xxxxxxxxxxxxx
